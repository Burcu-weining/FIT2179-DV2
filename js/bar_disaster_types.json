{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Natural Disaster Types Recorded in Malaysia",
    "subtitle": "Floods dominate the disaster record.",
    "font": "Georgia, Times New Roman, serif",
    "fontSize": 18,
    "color": "#1f5f99",
    "subtitleFont": "Arial, sans-serif",
    "subtitleFontSize": 12,
    "subtitleColor": "#222222",
    "anchor": "start"
  },
  "width": 620,
  "height": 360,
  "data": {
    "url": "data/disaster_type_summary.csv"
  },
  "transform": [
    {
      "filter": "indexof(lower(datum.disaster_type), 'mass movement') < 0"
    }
  ],
  "mark": {
    "type": "arc",
    "innerRadius": 45,
    "outerRadius": 145,
    "tooltip": true
  },
  "encoding": {
    "theta": {
      "field": "count",
      "type": "quantitative",
      "title": "Count"
    },
    "color": {
      "field": "disaster_type",
      "type": "nominal",
      "title": "Disaster type",
      "legend": {
        "orient": "right"
      },
      "scale": {
        "domain": [
          "Flood",
          "Storm",
          "Epidemic",
          "Drought",
          "Wildfire",
          "Earthquake"
        ],
        "range": [
          "#0072B2",
          "#56B4E9",
          "#E69F00",
          "#6A3D9A",
          "#D55E00",
          "#999999"
        ]
      }
    },
    "tooltip": [
      {
        "field": "disaster_type",
        "type": "nominal"
      },
      {
        "field": "count",
        "type": "quantitative"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}